# wms-server 로컬/배포 환경변수 예시. 실제 값은 .env(루트) 또는 deploy/.env 에 두고 커밋하지 않는다.
# 로컬 dev 는 아무것도 없어도 config-repo 기본값(localhost/H2)으로 동작한다 — 아래는 오버라이드용.

# ── DB (운영 PostgreSQL / 로컬은 비우면 임베디드 H2) ──
# DB_URL=jdbc:postgresql://localhost:5432/wms
# DB_USERNAME=wms
# DB_PASSWORD=wms
# JPA_DDL_AUTO=validate
POSTGRES_DB=wms

# ── Redis ──
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Kafka ──
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── JWT (gateway 검증 · master-service 발급이 동일 값 공유) ──
# JWT_SECRET=change-me-to-a-long-random-secret
# JWT_ISSUER=wms

# ── 서비스 디스커버리 / Config (부트스트랩) ──
# EUREKA_URL=http://localhost:19159/eureka/
# CONFIG_SERVER_URL=http://localhost:19159
