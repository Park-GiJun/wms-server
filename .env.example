# wms-server 로컬/배포 환경변수 예시. 실제 값은 .env(루트) 또는 deploy/.env 에 두고 커밋하지 않는다.
# datasource·JWT_SECRET 은 fallback 이 없다 — 값이 없으면 서비스가 부팅되지 않는 게 정상.
# 공유 홈서버 인프라 포트: pgsql 5432 · redis 6380 · kafka 9094

# ── DB (DB-per-service — 공유 Postgres 의 wms_* database, URL 은 서비스별 변수) ──
MASTER_DB_URL=jdbc:postgresql://<HOST>:5432/wms_master
INVENTORY_DB_URL=jdbc:postgresql://<HOST>:5432/wms_inventory
USER_DB_URL=jdbc:postgresql://<HOST>:5432/wms_user
DB_USERNAME=
DB_PASSWORD=

# ── Redis ──
REDIS_HOST=<HOST>
REDIS_PORT=6380
REDIS_PASSWORD=

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=<HOST>:9094

# ── JWT (gateway 검증 · user-service 발급이 동일 값 공유 — fallback 없음) ──
JWT_SECRET=change-me-to-a-long-random-secret
# JWT_ISSUER=wms
# JWT_VALIDITY_MINUTES=1440

# ── 서비스 디스커버리 / Config (부트스트랩) ──
# EUREKA_URL=http://localhost:19159/eureka/
# CONFIG_SERVER_URL=http://localhost:19159
