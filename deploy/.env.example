# wms-server 배포 환경변수 — deploy/.env 로 복사해 값을 채운다. deploy/.env 는 커밋 금지(.gitignore).
# 호스트/주소(config-server·eureka·DB·redis·kafka)는 compose 가 컨테이너명으로 주입하므로 여기엔 자격증명/시크릿만 둔다.

# ── 영속성 (공유 infra-postgres 의 wms_master / wms_inventory / wms_user DB) ──
DB_USERNAME=
DB_PASSWORD=

# ── Redis (공유 infra-redis — requirepass) ──
REDIS_PASSWORD=

# ── JWT (gateway 검증 · user-service 발급 — 동일 값 필수, fallback 없음이라 비우면 부팅 실패) ──
JWT_SECRET=
JWT_ISSUER=wms
JWT_VALIDITY_MINUTES=1440
